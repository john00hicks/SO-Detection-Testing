# Runas Administrator
cmd/PS>runas /noprofile /user:CHILD-DC\Administrator powershell.exe
cmd/PS> runas /user:Administrator cmd
cmd > powershell Start-Process cmd -Verb runas

# Test Connection
PS> tnc 192.168.31.130 -Port 8081
# Change password
PS> net user Administrator YourStrongPassword123!
# Account disable/enable Check
PS> Get-LocalUser -Name "Administrator" | Select-Object Name, Enabled
PS> Enable-LocalUser -Name "Administrator"
# Domain joined Check → to see what domain is this host joined
PS> (Get-WmiObject Win32_ComputerSystem).Domain
# Unjoin the Domain (You need the creds of Account from DC to authorised the unjoin & You need the DC to be ONLINE)
PS> Remove-Computer -UnjoinDomainCredential "DomainName\Administrator" -Restart
# Compress/Un-Zip
PS> 7z a <output-file> <input-file>	= Compress
PS> 7z a BVT-Binaries.7z BVT-Binaries
PS> 7z x BVT-Binaries.7z		= Extract/Unzip

